{
  "manifest_version": 3,
  "name": "Unicode Sentinel",
  "version": "0.1.0",
  "description": "Detects and highlights dangerous invisible Unicode characters in code blocks.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/src/content/content.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "dist/popup.html",
    "default_title": "Unicode Sentinel"
  },
  "options_page": "dist/options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "icons": {}
}
